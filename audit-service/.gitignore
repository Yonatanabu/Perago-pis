# === NODE DEPENDENCIES (IGNORE in all subfolders) ===
**/node_modules/
node_modules/

# === BUILD OUTPUTS ===
# For NestJS / TypeScript (audit-service)
**/dist/
**/build/
**/out/

# For Angular (if frontend uses it)
**/.angular/
**/*.js.map

# For React / Next.js (if frontend uses it)
**/.next/
**/out/

# === ENVIRONMENT VARIABLES ===
# Never commit secrets or .env files
.env
.env.*
!.env.example
*.env

# === LOGS ===
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === OS & SYSTEM FILES ===
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Linux
*.pid
*.seed
*.pid.lock

# === IDE / EDITOR FILES ===
.vscode/
.idea/
*.swp
*.swo
*~
.workspace
*.iml

# === TESTING & COVERAGE ===
**/coverage/
**/.nyc_output/
**/test-reports/

# === TEMPORARY FILES ===
**/.cache/
**/.temp/
**/tmp/
*.tmp

# === DOCKER (Usually keep docker-compose.yml, but ignore local overrides) ===
docker-compose.override.yml
*.dockerignore

# === PACKAGE MANAGERS ===
# Keep package-lock.json (it's good to commit), but ignore if using yarn vs npm mixups
yarn-error.log
pnpm-debug.log